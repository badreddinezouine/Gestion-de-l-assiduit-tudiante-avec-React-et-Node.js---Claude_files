const Grade     = require('../models/Grade');
const Course    = require('../models/Course');
const Professor = require('../models/Professor');
const User      = require('../models/User');
const Student   = require('../models/Student'); // ✅ AJOUTÉ

// ─────────────────────────────────────────────────────────────
//  POST /api/grades  → créer une évaluation
// ─────────────────────────────────────────────────────────────
exports.createGrade = async (req, res) => {
  try {
    const professor = await Professor.findOne({ utilisateurId: req.user.id });
    if (!professor) {
      return res.status(404).json({ success: false, error: 'Profil professeur non trouvé' });
    }

    const { coursId, etudiantId, typeEvaluation, note, typeParticipation, commentaire } = req.body;

    if (!coursId || !etudiantId) {
      return res.status(400).json({ success: false, error: 'coursId et etudiantId requis' });
    }

    const grade = await Grade.create({
      professeurId:    professor._id,
      coursId,
      etudiantId,
      typeEvaluation:  typeEvaluation  || 'EXAMEN',
      note:            note            ?? null,
      typeParticipation: typeParticipation || 'ACTIVE',
      commentaire:     commentaire     || '',
    });

    // Populer pour retourner les infos lisibles
    const populated = await Grade.findById(grade._id)
      .populate('coursId',    'intitule code')
      .populate('etudiantId', 'nom prenom email');

    return res.status(201).json({ success: true, grade: populated });

  } catch (err) {
    console.error('createGrade error:', err);
    return res.status(500).json({ success: false, error: err.message });
  }
};

// ─────────────────────────────────────────────────────────────
//  GET /api/grades/my  → toutes les notes du professeur connecté
// ─────────────────────────────────────────────────────────────
exports.getMyGrades = async (req, res) => {
  try {
    const professor = await Professor.findOne({ utilisateurId: req.user.id });
    if (!professor) {
      return res.status(404).json({ success: false, error: 'Profil professeur non trouvé' });
    }

    const grades = await Grade.find({ professeurId: professor._id })
      .populate('coursId',    'intitule code')
      .populate('etudiantId', 'nom prenom email')
      .sort({ createdAt: -1 });

    return res.json({ success: true, grades });

  } catch (err) {
    return res.status(500).json({ success: false, error: err.message });
  }
};

// ─────────────────────────────────────────────────────────────
//  DELETE /api/grades/:id  → supprimer une évaluation
// ─────────────────────────────────────────────────────────────
exports.deleteGrade = async (req, res) => {
  try {
    await Grade.findByIdAndDelete(req.params.id);
    return res.json({ success: true, message: 'Évaluation supprimée' });
  } catch (err) {
    return res.status(500).json({ success: false, error: err.message });
  }
};

// ─────────────────────────────────────────────────────────────
//  GET /api/grades/students-for-course/:courseId
//  → étudiants inscrits à ce cours (pour le select)
//  ✅ ✅ ✅ VERSION CORRIGÉE ✅ ✅ ✅
// ─────────────────────────────────────────────────────────────
exports.getStudentsForCourse = async (req, res) => {
  try {
    // ✅ Charger le cours avec populate Student → User
    const course = await Course.findById(req.params.courseId)
      .populate({
        path: 'etudiantsInscrits',      // ← Student documents
        populate: {
          path: 'utilisateurId',        // ← User documents
          select: 'nom prenom email'
        }
      });

    if (!course) {
      return res.status(404).json({ success: false, error: 'Cours non trouvé' });
    }

    // ✅ Formater les données pour le frontend
    const formatted = course.etudiantsInscrits
      .filter(student => student && student.utilisateurId) // Filtrer les null/undefined
      .map(student => ({
        id: String(student.utilisateurId._id),     // ← ID du User (pour etudiantId dans Grade)
        nom: student.utilisateurId.nom,
        prenom: student.utilisateurId.prenom,
        email: student.utilisateurId.email,
      }));

    // ✅ Logs pour débogage
    console.log('─────────────────────────────────────────────────────');
    console.log(`📚 Cours sélectionné: ${course.intitule} (${course.code})`);
    console.log(`👥 Nombre d'étudiants inscrits: ${formatted.length}`);
    if (formatted.length > 0) {
      console.log('📋 Liste des étudiants:');
      formatted.forEach((s, i) => {
        console.log(`   ${i + 1}. ${s.prenom} ${s.nom} (${s.email})`);
      });
    } else {
      console.log('⚠️  Aucun étudiant inscrit à ce cours');
    }
    console.log('─────────────────────────────────────────────────────');

    return res.json({ success: true, students: formatted });

  } catch (err) {
    console.error('❌ getStudentsForCourse error:', err);
    return res.status(500).json({ success: false, error: err.message });
  }
};